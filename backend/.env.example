# Copy this file to .env and fill in real values before running.

# Postgres in production; sqlite+aiosqlite:///./dev.db works for local dev with zero setup.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/freelanceflow

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_ORIGINS=http://localhost:3000

APP_ENV=development
DEBUG=true
